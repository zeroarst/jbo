#!/usr/bin/env bash
# jbo-wrap: wrap a command and add clickable OSC 8 jbo:// links to path:line output.
# PTY mode (WSL/Linux): full interactive support via Python.
# Pipe mode (Git Bash / Windows): awk-based, no Python needed.

# ── paths ─────────────────────────────────────────────────────────────────────
_JBO_CONFIG_DIR="${HOME}/.config/jbo"
_JBO_PROJECTS="${_JBO_CONFIG_DIR}/projects.conf"
_JBO_WRAP_PY="${_JBO_CONFIG_DIR}/jbo-wrap.py"

# ── helpers ───────────────────────────────────────────────────────────────────

# Walk up from $PWD looking for .git/ (dir or file — gitfile case); fall back to $PWD.
_jbo_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ] && [ -n "$dir" ]; do
        if [ -e "$dir/.git" ]; then
            printf '%s\n' "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    printf '%s\n' "$PWD"
}

# Look up IDE for a project root from projects.conf.
_jbo_lookup_ide() {
    local root="$1"
    [ -f "$_JBO_PROJECTS" ] || return 1
    local line
    line=$(grep -F -- "$root=" "$_JBO_PROJECTS" 2>/dev/null | head -1)
    [ -n "$line" ] || return 1
    printf '%s\n' "${line#*=}"
}

# Save IDE choice for project root, replacing any prior entry.
_jbo_save_ide() {
    local root="$1" ide="$2"
    mkdir -p "$_JBO_CONFIG_DIR"
    local tmp="${_JBO_PROJECTS}.tmp.$$"
    if [ -f "$_JBO_PROJECTS" ]; then
        grep -F -v -- "$root=" "$_JBO_PROJECTS" > "$tmp" 2>/dev/null || true
    else
        : > "$tmp"
    fi
    printf '%s=%s\n' "$root" "$ide" >> "$tmp"
    mv "$tmp" "$_JBO_PROJECTS"
}

# Resolve LOCALAPPDATA as a unix path (WSL / Git Bash / Cygwin).
_jbo_localappdata_unix() {
    local la_win="${LOCALAPPDATA:-}"
    if [ -z "$la_win" ] && command -v powershell.exe >/dev/null 2>&1; then
        la_win=$(powershell.exe -NoProfile -Command 'Write-Output $env:LOCALAPPDATA' </dev/null 2>/dev/null | tr -d '\r')
    fi
    [ -n "$la_win" ] || return 1
    if command -v wslpath >/dev/null 2>&1; then
        wslpath -u "$la_win" 2>/dev/null | tr -d '\r'
    elif command -v cygpath >/dev/null 2>&1; then
        cygpath -u "$la_win" 2>/dev/null
    else
        printf '%s\n' "$la_win"
    fi
}

# IDE names for which the global config.json has a non-empty exe path.
# Falls back to all three if config.json is missing.
_jbo_installed_ides() {
    local la cfg=""
    la=$(_jbo_localappdata_unix 2>/dev/null || true)
    [ -n "$la" ] && cfg="$la/jbo/config.json"

    if [ -f "$cfg" ]; then
        grep -oE '"(webstorm|androidstudio|intellij)"[[:space:]]*:[[:space:]]*"[^"]+"' "$cfg" 2>/dev/null \
            | sed -E 's/"([^"]+)"[[:space:]]*:.*/\1/'
    else
        printf 'webstorm\nandroidstudio\nintellij\n'
    fi
}

# Score project markers; print recommended IDE.
_jbo_recommend_ide() {
    local root="$1"
    local ws=0 ij=0 as=0 f

    # Android Studio markers
    [ -f "$root/AndroidManifest.xml" ] && as=$((as+10))
    if find "$root" -maxdepth 3 \
            \( -name node_modules -o -name .git -o -name vendor -o -name target -o -name build -o -name dist \) -prune \
            -o -name AndroidManifest.xml -print 2>/dev/null | head -1 | grep -q .; then
        as=$((as+10))
    fi
    [ -f "$root/local.properties" ] && as=$((as+5))
    for f in "$root"/build.gradle "$root"/build.gradle.kts "$root"/app/build.gradle "$root"/app/build.gradle.kts; do
        if [ -f "$f" ] && grep -q "com.android" "$f" 2>/dev/null; then
            as=$((as+10))
            break
        fi
    done

    # WebStorm markers
    [ -f "$root/package.json" ]    && ws=$((ws+5))
    [ -f "$root/tsconfig.json" ]   && ws=$((ws+3))
    [ -f "$root/angular.json" ]    && ws=$((ws+5))
    for f in "$root"/next.config.* "$root"/nuxt.config.* "$root"/vite.config.* "$root"/svelte.config.*; do
        [ -f "$f" ] && { ws=$((ws+3)); break; }
    done

    # IntelliJ markers (Java/Kotlin/Scala, non-Android)
    [ -f "$root/pom.xml" ]   && ij=$((ij+10))
    [ -f "$root/build.sbt" ] && ij=$((ij+10))
    for f in "$root"/*.iml; do
        [ -f "$f" ] && { ij=$((ij+3)); break; }
    done
    if [ "$as" -eq 0 ]; then
        [ -f "$root/build.gradle" ]         && ij=$((ij+3))
        [ -f "$root/build.gradle.kts" ]     && ij=$((ij+3))
        [ -f "$root/settings.gradle" ]      && ij=$((ij+3))
        [ -f "$root/settings.gradle.kts" ]  && ij=$((ij+3))
    fi

    if [ "$as" -gt "$ws" ] && [ "$as" -gt "$ij" ]; then
        printf 'androidstudio\n'
    elif [ "$ij" -gt "$ws" ]; then
        printf 'intellij\n'
    else
        printf 'webstorm\n'
    fi
}

_jbo_ide_label() {
    case "$1" in
        webstorm)      printf 'WebStorm' ;;
        androidstudio) printf 'Android Studio' ;;
        intellij)      printf 'IntelliJ IDEA' ;;
        *)             printf '%s' "$1" ;;
    esac
}

# Numeric fallback picker (used when raw-mode TUI isn't available).
# Stdout: chosen IDE name (or empty string on skip).  Stderr: menu + prompts.
_jbo_pick_ide_numeric() {
    local root="$1" recommended="$2" installed="$3"

    {
        printf '\n'
        printf 'jbo-wrap: no IDE configured for this project.\n'
        printf '  Project root: %s\n\n' "$root"

        local i=1 ide label
        while IFS= read -r ide; do
            [ -n "$ide" ] || continue
            label=$(_jbo_ide_label "$ide")
            if [ "$ide" = "$recommended" ]; then
                printf '  %d. %s   ← recommended\n' "$i" "$label"
            else
                printf '  %d. %s\n' "$i" "$label"
            fi
            i=$((i+1))
        done <<< "$installed"
        printf '  s. Skip — use default this time, ask again next run\n\n'
        printf 'Choose [press Enter for recommended]: '
    } >&2

    local answer
    read -r answer || answer=""

    case "$answer" in
        "") printf '%s\n' "$recommended"; return 0 ;;
        [Ss]*) return 0 ;;
    esac

    local idx=1 ide chosen=""
    while IFS= read -r ide; do
        [ -n "$ide" ] || continue
        if [ "$answer" = "$idx" ]; then
            chosen="$ide"
            break
        fi
        idx=$((idx+1))
    done <<< "$installed"

    if [ -n "$chosen" ]; then
        printf '%s\n' "$chosen"
    else
        printf 'Invalid choice — using recommended (%s).\n' "$recommended" >&2
        printf '%s\n' "$recommended"
    fi
}

# Arrow-key TUI picker. ↑/↓ (or k/j) to move, Enter to select, s/q/Esc to skip.
# Stdout: chosen IDE name (or empty string on skip).  Stderr: menu UI.
_jbo_pick_ide_tui() {
    local root="$1" recommended="$2" installed="$3"

    # Build array of options: each installed IDE + a synthetic "__skip__".
    local options=() ide
    while IFS= read -r ide; do
        [ -n "$ide" ] && options+=("$ide")
    done <<< "$installed"
    options+=("__skip__")

    # Initial selection = recommended IDE.
    local selected=0 i
    for i in "${!options[@]}"; do
        [ "${options[$i]}" = "$recommended" ] && { selected=$i; break; }
    done

    # Save terminal state; bail to numeric fallback if raw mode isn't available.
    local saved_stty
    saved_stty=$(stty -g </dev/tty 2>/dev/null) || {
        _jbo_pick_ide_numeric "$root" "$recommended" "$installed"
        return $?
    }

    # Cursor + style codes.
    local ESC=$'\033'
    local HIDE="${ESC}[?25l" SHOW="${ESC}[?25h"
    local BOLD="${ESC}[1m" DIM="${ESC}[2m" RST="${ESC}[0m"
    local BCY="${ESC}[1;36m"   # bold cyan — selection caret
    local BW="${ESC}[1;37m"    # bold white — selected label
    local BYL="${ESC}[1;33m"   # bold yellow — recommended marker
    local CLR_LINE="${ESC}[K"

    _jbo_tui_cleanup() {
        stty "$saved_stty" </dev/tty 2>/dev/null
        printf '%s' "$SHOW" >&2
    }
    trap '_jbo_tui_cleanup' EXIT INT TERM

    # Header (printed once, stays put).
    {
        printf '\n'
        printf '%sjbo-wrap%s: choose IDE for this project\n' "$BOLD" "$RST"
        printf '  %sProject root: %s%s\n' "$DIM" "$root" "$RST"
        printf '  %s↑/↓ · Enter · s skip · q/Esc quit%s\n\n' "$DIM" "$RST"
        printf '%s' "$HIDE"
    } >&2

    _jbo_tui_draw() {
        local idx opt label tail is_skip
        for idx in "${!options[@]}"; do
            opt="${options[$idx]}"
            tail=""
            is_skip=0
            if [ "$opt" = "__skip__" ]; then
                label="Skip — use default this time, ask again next run"
                is_skip=1
            else
                label=$(_jbo_ide_label "$opt")
                [ "$opt" = "$recommended" ] && tail="                ${BYL}★ recommended${RST}"
            fi

            if [ "$idx" = "$selected" ]; then
                printf '  %s❯%s %s%s%s%s%s\n' "$BCY" "$RST" "$BW" "$label" "$RST" "$tail" "$CLR_LINE" >&2
            elif [ "$is_skip" = "1" ]; then
                printf '    %s%s%s%s\n' "$DIM" "$label" "$RST" "$CLR_LINE" >&2
            else
                printf '    %s%s%s\n' "$label" "$tail" "$CLR_LINE" >&2
            fi
        done
    }

    _jbo_tui_draw

    # Raw mode: no echo, no line buffering, no signal interpretation.
    stty -echo -icanon -isig min 1 time 0 </dev/tty 2>/dev/null

    local key rest result="" done=0
    while [ "$done" = "0" ]; do
        IFS= read -rsn1 key </dev/tty || break
        case "$key" in
            "$ESC")
                # Try to consume "[A" / "[B" etc. with a short timeout.
                rest=""
                IFS= read -rsn2 -t 1 rest </dev/tty 2>/dev/null || rest=""
                case "$rest" in
                    '[A') selected=$(( (selected - 1 + ${#options[@]}) % ${#options[@]} )) ;;
                    '[B') selected=$(( (selected + 1) % ${#options[@]} )) ;;
                    '')   done=1 ;;   # bare Esc → quit
                esac
                ;;
            k|K) selected=$(( (selected - 1 + ${#options[@]}) % ${#options[@]} )) ;;
            j|J) selected=$(( (selected + 1) % ${#options[@]} )) ;;
            ""|$'\n'|$'\r')
                if [ "${options[$selected]}" = "__skip__" ]; then
                    result=""
                else
                    result="${options[$selected]}"
                fi
                done=1
                ;;
            s|S|q|Q|$'\x03'|$'\x04') done=1 ;;
        esac

        if [ "$done" = "0" ]; then
            printf '%s[%dA' "$ESC" "${#options[@]}" >&2
            _jbo_tui_draw
        fi
    done

    # Restore terminal and trap.
    _jbo_tui_cleanup
    trap - EXIT INT TERM
    printf '\n' >&2

    printf '%s' "$result"
}

# Entry point — try the TUI; the TUI itself falls back to numeric on raw-mode failure.
_jbo_pick_ide() {
    local root="$1" recommended installed

    recommended=$(_jbo_recommend_ide "$root")
    installed=$(_jbo_installed_ides)

    # If recommendation isn't installed, fall back to the first installed.
    if ! printf '%s\n' "$installed" | grep -qx "$recommended"; then
        recommended=$(printf '%s\n' "$installed" | head -1)
    fi

    _jbo_pick_ide_tui "$root" "$recommended" "$installed"
}

# Print current project's IDE config.
_jbo_cmd_show_config() {
    local root ide
    root=$(_jbo_project_root)
    ide=$(_jbo_lookup_ide "$root" 2>/dev/null || true)
    printf 'project: %s\n' "$root"
    if [ -n "$ide" ]; then
        printf 'ide:     %s (%s)\n' "$ide" "$(_jbo_ide_label "$ide")"
        printf 'stored:  %s\n' "$_JBO_PROJECTS"
    else
        printf 'ide:     (not configured — will prompt on first run)\n'
        [ -n "${JBO_IDE:-}" ] && printf 'env:     JBO_IDE=%s\n' "$JBO_IDE"
    fi
}

# Scan projects.conf; report stale entries; offer interactive prune.
_jbo_cmd_validate() {
    if [ ! -f "$_JBO_PROJECTS" ]; then
        printf 'No projects configured (%s does not exist).\n' "$_JBO_PROJECTS"
        return 0
    fi

    local stale_count=0 valid_count=0 path ide
    while IFS='=' read -r path ide; do
        [ -n "$path" ] || continue
        if [ -d "$path" ]; then
            valid_count=$((valid_count+1))
            printf '  ✓ %s → %s\n' "$path" "$ide"
        else
            stale_count=$((stale_count+1))
            printf '  ✗ %s → %s  (directory missing)\n' "$path" "$ide"
        fi
    done < "$_JBO_PROJECTS"

    printf '\n%d valid, %d stale.\n' "$valid_count" "$stale_count"
    [ "$stale_count" -eq 0 ] && return 0

    if [ ! -t 0 ]; then
        printf '(non-tty — leaving stale entries in place. Re-run interactively to prune.)\n'
        return 0
    fi

    printf 'Remove stale entries? [y/N]: '
    local answer
    read -r answer || answer=""
    case "$answer" in
        [Yy]*)
            local tmp="${_JBO_PROJECTS}.tmp.$$"
            : > "$tmp"
            while IFS='=' read -r path ide; do
                [ -n "$path" ] || continue
                [ -d "$path" ] && printf '%s=%s\n' "$path" "$ide" >> "$tmp"
            done < "$_JBO_PROJECTS"
            mv "$tmp" "$_JBO_PROJECTS"
            printf 'Removed %d stale entries.\n' "$stale_count"
            ;;
        *) printf 'Keeping stale entries.\n' ;;
    esac
}

# ── flag parsing ──────────────────────────────────────────────────────────────
_JBO_RECONFIGURE=0
while [ $# -gt 0 ]; do
    case "$1" in
        --show-config) _jbo_cmd_show_config; exit 0 ;;
        --validate)    _jbo_cmd_validate; exit 0 ;;
        --reconfigure) _JBO_RECONFIGURE=1; shift ;;
        --help|-h)
            cat >&2 <<'USAGE'
Usage: jbo-wrap [flags] <command> [args...]

Flags:
  --reconfigure   Re-prompt for the IDE used by this project's links.
  --show-config   Print the IDE configured for the current project.
  --validate      Scan saved projects for missing directories; offer to prune.
  -h, --help      Show this help.

Environment:
  JBO_IDE         Fallback IDE when no project is configured.
                  (webstorm | androidstudio | intellij)
  JBO_SKIP_INIT   If set to 1, never prompt — fall back to JBO_IDE / webstorm.
USAGE
            exit 0
            ;;
        --) shift; break ;;
        *) break ;;
    esac
done

if [ $# -eq 0 ]; then
    echo "Usage: jbo-wrap [flags] <command> [args...]   (try --help)" >&2
    exit 1
fi

# ── resolve IDE for this project ──────────────────────────────────────────────
_JBO_ROOT=$(_jbo_project_root)
_IDE_FROM_CONF=$(_jbo_lookup_ide "$_JBO_ROOT" 2>/dev/null || true)

if [ "$_JBO_RECONFIGURE" = "1" ] || [ -z "$_IDE_FROM_CONF" ]; then
    if [ "${JBO_SKIP_INIT:-0}" = "1" ] || [ ! -t 0 ] || [ ! -t 2 ]; then
        # Non-interactive: silent fallback, no save.
        IDE="${JBO_IDE:-webstorm}"
    else
        _PICKED=$(_jbo_pick_ide "$_JBO_ROOT")
        if [ -n "$_PICKED" ]; then
            _jbo_save_ide "$_JBO_ROOT" "$_PICKED"
            IDE="$_PICKED"
            {
                printf '\n'
                printf 'jbo-wrap: saved %s → %s\n' "$_JBO_ROOT" "$_PICKED"
                printf '  • Change later:  jbo-wrap --reconfigure %s\n' "${1:-claude}"
                printf '  • View current:  jbo-wrap --show-config\n'
                printf '  • Stored in:     %s\n\n' "$_JBO_PROJECTS"
            } >&2
        else
            IDE="${JBO_IDE:-webstorm}"
        fi
    fi
else
    IDE="$_IDE_FROM_CONF"
fi

export JBO_IDE="$IDE"

# ── find Python (skip Windows Store stubs) ───────────────────────────────────
_PYTHON=""
for _cmd in python3 python python3.exe python.exe; do
    _path=$(command -v "$_cmd" 2>/dev/null) || continue
    case "$_path" in */WindowsApps/*) continue ;; esac
    if "$_cmd" -c "import sys" 2>/dev/null; then
        _PYTHON="$_cmd"
        break
    fi
done
# Fallback: search LOCALAPPDATA\Programs\Python\ (common Windows install location)
if [ -z "$_PYTHON" ] && [ -n "${LOCALAPPDATA:-}" ]; then
    _la=$(cygpath -u "$LOCALAPPDATA" 2>/dev/null || true)
    if [ -n "$_la" ]; then
        for _py in "$_la"/Programs/Python/Python*/python.exe; do
            [ -f "$_py" ] || continue
            if "$_py" -c "import sys" 2>/dev/null; then
                _PYTHON="$_py"
                break
            fi
        done
    fi
fi

# ── PTY mode (Unix pty or Windows pywinpty) ───────────────────────────────────
if [ -n "$_PYTHON" ] && [ -f "$_JBO_WRAP_PY" ]; then
    if "$_PYTHON" -c "import pty, fcntl, termios" 2>/dev/null || \
       "$_PYTHON" -c "import winpty" 2>/dev/null; then
        exec "$_PYTHON" "$_JBO_WRAP_PY" "$@"
    fi
fi

# ── Pipe mode (awk, no Python required) ───────────────────────────────────────
# Limitation: awk cannot cheaply check file existence, so this fallback only
# handles absolute paths with a `:line` suffix (current regex). Relative-path
# autodetection requires the Python branch above. Document this in the README.
"$@" 2>&1 | awk -v ide="$IDE" '
{
    line = $0
    result = ""
    while (1) {
        if (match(line, /[A-Za-z]:[\/\\][^[:space:][:cntrl:]]*\.[a-zA-Z0-9]{1,10}:[0-9]+|\/[^[:space:][:cntrl:]]*\.[a-zA-Z0-9]{1,10}:[0-9]+/)) {
            result = result substr(line, 1, RSTART - 1)
            matched = substr(line, RSTART, RLENGTH)
            line   = substr(line, RSTART + RLENGTH)
            if (match(matched, /:[0-9]+$/)) {
                path   = substr(matched, 1, RSTART - 1)
                lineno = substr(matched, RSTART + 1)
                gsub(/\\/, "/", path)
                url = "jbo://open?ide=" ide "&file=" path "&line=" lineno
                result = result "\033]8;;" url "\033\\" matched "\033]8;;\033\\"
            } else {
                result = result matched
            }
        } else {
            result = result line
            break
        }
    }
    print result
    fflush()
}
'
exit "${PIPESTATUS[0]}"
