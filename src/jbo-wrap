#!/usr/bin/env bash
# jbo-wrap: wrap a command and add clickable OSC 8 jbo:// links to path:line output.
# PTY mode (WSL/Linux): full interactive support via Python.
# Pipe mode (Git Bash / Windows): awk-based, no Python needed.

IDE="${JBO_IDE:-webstorm}"

if [ $# -eq 0 ]; then
    echo "Usage: jbo-wrap <command> [args...]" >&2
    exit 1
fi

# ── find Python (skip Windows Store stubs) ───────────────────────────────────
_PYTHON=""
for _cmd in python3 python python3.exe python.exe; do
    _path=$(command -v "$_cmd" 2>/dev/null) || continue
    case "$_path" in */WindowsApps/*) continue ;; esac
    if "$_cmd" -c "import sys" 2>/dev/null; then
        _PYTHON="$_cmd"
        break
    fi
done
# Fallback: search LOCALAPPDATA\Programs\Python\ (common Windows install location)
if [ -z "$_PYTHON" ] && [ -n "${LOCALAPPDATA:-}" ]; then
    _la=$(cygpath -u "$LOCALAPPDATA" 2>/dev/null || true)
    if [ -n "$_la" ]; then
        for _py in "$_la"/Programs/Python/Python*/python.exe; do
            [ -f "$_py" ] || continue
            if "$_py" -c "import sys" 2>/dev/null; then
                _PYTHON="$_py"
                break
            fi
        done
    fi
fi

# ── PTY mode (Unix pty or Windows pywinpty) ───────────────────────────────────
_JBO_WRAP_PY="${HOME}/.config/jbo/jbo-wrap.py"
if [ -n "$_PYTHON" ] && [ -f "$_JBO_WRAP_PY" ]; then
    if "$_PYTHON" -c "import pty, fcntl, termios" 2>/dev/null || \
       "$_PYTHON" -c "import winpty" 2>/dev/null; then
        exec "$_PYTHON" "$_JBO_WRAP_PY" "$@"
    fi
fi

# ── Pipe mode (awk, no Python required) ───────────────────────────────────────
"$@" 2>&1 | awk -v ide="$IDE" '
{
    line = $0
    result = ""
    while (1) {
        if (match(line, /[A-Za-z]:[\/\\][^[:space:][:cntrl:]]*\.[a-zA-Z0-9]{1,10}:[0-9]+|\/[^[:space:][:cntrl:]]*\.[a-zA-Z0-9]{1,10}:[0-9]+/)) {
            result = result substr(line, 1, RSTART - 1)
            matched = substr(line, RSTART, RLENGTH)
            line   = substr(line, RSTART + RLENGTH)
            if (match(matched, /:[0-9]+$/)) {
                path   = substr(matched, 1, RSTART - 1)
                lineno = substr(matched, RSTART + 1)
                gsub(/\\/, "/", path)
                url = "jbo://open?ide=" ide "&file=" path "&line=" lineno
                result = result "\033]8;;" url "\033\\" matched "\033]8;;\033\\"
            } else {
                result = result matched
            }
        } else {
            result = result line
            break
        }
    }
    print result
    fflush()
}
'
exit "${PIPESTATUS[0]}"